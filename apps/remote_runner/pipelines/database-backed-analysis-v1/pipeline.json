{
  "pipelineId": "database-backed-analysis-v1",
  "name": "Database Backed Analysis",
  "version": "0.1.0",
  "description": "Validation template for a workflow that depends on both uploaded reads and a reference database before analysis.",
  "category": "DAG Validation",
  "icon": "database",
  "tags": [
    "dag",
    "database",
    "reference",
    "template"
  ],
  "author": "H2OMeta",
  "license": "internal",
  "status": "installed",
  "enabled": true,
  "snakefile": "workflow/Snakefile",
  "inputsSchema": {
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "object",
      "required": [
        "uploadId"
      ],
      "properties": {
        "uploadId": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "default": "reads"
        }
      }
    }
  },
  "paramsSchema": {
    "type": "object",
    "properties": {
      "identity_threshold": {
        "type": "number",
        "title": "Identity threshold",
        "minimum": 0,
        "maximum": 1,
        "default": 0.97,
        "description": "Minimum identity used when matching reads against the reference database."
      }
    },
    "additionalProperties": true
  },
  "outputSchema": {
    "type": "object",
    "artifacts": [
      {
        "kind": "table",
        "mimeType": "text/tab-separated-values",
        "name": "classified-reads.tsv",
        "key": "classified_reads"
      },
      {
        "kind": "report",
        "mimeType": "text/html",
        "name": "classification-report.html",
        "key": "report"
      },
      {
        "kind": "log",
        "mimeType": "text/plain",
        "name": "raw-log.txt",
        "key": "raw_log"
      }
    ]
  },
  "uiSchema": {
    "inputs": {
      "widget": "file-upload",
      "accept": ".fastq,.fq,.txt,.gz,text/plain,application/gzip",
      "roleDefault": "reads"
    },
    "params": {
      "identity_threshold": {
        "widget": "number",
        "label": "Identity threshold"
      }
    },
    "graph": {
      "defaultView": "rulegraph",
      "nodes": [
        {
          "id": "reads",
          "label": "reads",
          "title": "Input reads",
          "group": "input",
          "kind": "input",
          "description": "Uploaded reads that will be classified against a reference database.",
          "role": "reads",
          "outputs": [
            "reads.fastq.gz"
          ],
          "operationHints": [
            "fileUpload"
          ]
        },
        {
          "id": "reference_database",
          "label": "reference database",
          "title": "Reference database",
          "group": "database",
          "kind": "database",
          "description": "Reference database binding used for classification.",
          "role": "reference_database",
          "outputs": [
            "reference-index"
          ],
          "runtimeStatusKey": "database:reference_database",
          "resourceHints": {
            "storage": "20 GiB",
            "memory": "4 GiB"
          },
          "operationHints": [
            "databaseBinding"
          ]
        },
        {
          "id": "prepare_inputs",
          "label": "prepare_inputs",
          "title": "Prepare inputs",
          "group": "validation",
          "kind": "rule",
          "description": "Normalizes read names and validates that the reference database is available.",
          "inputs": [
            "reads.fastq.gz",
            "reference-index"
          ],
          "outputs": [
            "prepared-reads.tsv",
            "database-check.json"
          ],
          "runtimeStatusKey": "rule:prepare_inputs",
          "resourceHints": {
            "threads": 1,
            "memory": "1 GiB"
          },
          "retryPolicy": {
            "maxAttempts": 2,
            "strategy": "on-error",
            "delaySeconds": 10
          }
        },
        {
          "id": "classify_reads",
          "label": "classify_reads",
          "title": "Classify reads",
          "group": "analysis",
          "kind": "rule",
          "description": "Matches prepared reads against the reference index using the identity threshold.",
          "params": [
            "identity_threshold"
          ],
          "inputs": [
            "prepared-reads.tsv",
            "reference-index",
            "identity_threshold"
          ],
          "outputs": [
            "classified-reads.tsv"
          ],
          "runtimeStatusKey": "rule:classify_reads",
          "resourceHints": {
            "threads": 4,
            "memory": "8 GiB",
            "queue": "analysis"
          },
          "retryPolicy": {
            "maxAttempts": 3,
            "strategy": "on-failure",
            "delaySeconds": 30
          },
          "operationHints": [
            "editableParams",
            "databaseBound"
          ]
        },
        {
          "id": "render_report",
          "label": "render_report",
          "title": "Render classification report",
          "group": "report",
          "kind": "rule",
          "description": "Summarizes classification hits and database provenance in HTML and text logs.",
          "inputs": [
            "classified-reads.tsv",
            "database-check.json"
          ],
          "outputs": [
            "classification-report.html",
            "raw-log.txt"
          ],
          "runtimeStatusKey": "rule:render_report",
          "resourceHints": {
            "threads": 1,
            "memory": "1 GiB"
          }
        },
        {
          "id": "outputs",
          "label": "workflow outputs",
          "title": "Results",
          "group": "output",
          "kind": "output",
          "description": "Classification table, report, and raw provenance log.",
          "inputs": [
            "classified-reads.tsv",
            "classification-report.html",
            "raw-log.txt"
          ],
          "artifacts": [
            {
              "kind": "table",
              "name": "classified-reads.tsv",
              "mimeType": "text/tab-separated-values"
            },
            {
              "kind": "report",
              "name": "classification-report.html",
              "mimeType": "text/html"
            },
            {
              "kind": "log",
              "name": "raw-log.txt",
              "mimeType": "text/plain"
            }
          ],
          "operationHints": [
            "expectedOutputs"
          ]
        }
      ],
      "edges": [
        {
          "from": "reads",
          "to": "prepare_inputs"
        },
        {
          "from": "reference_database",
          "to": "prepare_inputs"
        },
        {
          "from": "prepare_inputs",
          "to": "classify_reads"
        },
        {
          "from": "reference_database",
          "to": "classify_reads"
        },
        {
          "from": "classify_reads",
          "to": "render_report"
        },
        {
          "from": "classify_reads",
          "to": "outputs"
        },
        {
          "from": "render_report",
          "to": "outputs"
        }
      ]
    }
  },
  "execution": {
    "outputs": {
      "classified_reads": "classified-reads.tsv",
      "report": "classification-report.html",
      "raw_log": "raw-log.txt"
    }
  },
  "resources": {
    "reference_database": {
      "type": "database",
      "required": false,
      "description": "Optional reference database binding used by database-backed analyses.",
      "configKey": "reference_database"
    }
  }
}
