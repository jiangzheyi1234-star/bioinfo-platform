{
  "pipelineId": "generated-tool-run-v1",
  "name": "Generated Tool Run",
  "version": "0.1.0",
  "description": "Run a saved WorkflowDesignDraft as generated Snakemake rules with per-rule conda environments.",
  "category": "Tool Workflows",
  "icon": "wrench",
  "tags": [
    "tools",
    "snakemake",
    "generated"
  ],
  "author": "H2OMeta",
  "license": "internal",
  "status": "installed",
  "enabled": true,
  "snakefile": "workflow/Snakefile",
  "inputsSchema": {
    "type": "array",
    "minItems": 1,
    "items": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "uploadId"
          ],
          "properties": {
            "uploadId": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "default": "input"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifactId"
          ],
          "properties": {
            "artifactId": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "default": "input"
            },
            "upstreamRunId": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifactBlobId",
            "materializationId"
          ],
          "properties": {
            "artifactBlobId": {
              "type": "string",
              "minLength": 1
            },
            "materializationId": {
              "type": "string",
              "minLength": 1
            },
            "sourceArtifactId": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "default": "input"
            },
            "upstreamRunId": {
              "type": "string"
            }
          }
        }
      ]
    }
  },
  "paramsSchema": {
    "type": "object",
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "artifacts": [
      {
        "kind": "log",
        "mimeType": "text/plain",
        "name": "tool-output.txt",
        "key": "tool_output"
      }
    ]
  },
  "uiSchema": {
    "inputs": {
      "widget": "file-upload",
      "accept": "*",
      "roleDefault": "input"
    },
    "workflowDesign": {
      "widget": "workflow-design-draft"
    }
  },
  "execution": {
    "outputs": {
      "tool_output": "tool-output.txt"
    }
  },
  "resources": {}
}
