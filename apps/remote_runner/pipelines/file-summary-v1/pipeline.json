{
  "pipelineId": "file-summary-v1",
  "name": "File Summary",
  "version": "1.0.0",
  "description": "Summarize uploaded FASTQ, gzip, or text inputs into a TSV and HTML report.",
  "category": "Sequence Utilities",
  "icon": "file-text",
  "tags": ["fastq", "summary", "quality-control"],
  "author": "H2OMeta",
  "license": "internal",
  "status": "installed",
  "enabled": true,
  "snakefile": "Snakefile",
  "inputsSchema": {
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "object",
      "required": ["uploadId"],
      "properties": {
        "uploadId": { "type": "string", "minLength": 1 },
        "filename": { "type": "string" },
        "role": { "type": "string", "default": "reads" }
      }
    }
  },
  "paramsSchema": {
    "type": "object",
    "properties": {
      "threads": {
        "type": "integer",
        "minimum": 1,
        "maximum": 64,
        "default": 1
      }
    },
    "additionalProperties": true
  },
  "outputSchema": {
    "type": "object",
    "artifacts": [
      { "kind": "table", "mimeType": "text/tab-separated-values", "name": "summary.tsv" },
      { "kind": "report", "mimeType": "text/html", "name": "run-report.html" },
      { "kind": "log", "mimeType": "text/plain", "name": "raw-log.txt" }
    ]
  },
  "uiSchema": {
    "inputs": {
      "widget": "file-upload",
      "accept": ".fastq,.fq,.txt,.gz,text/plain,application/gzip",
      "roleDefault": "reads"
    },
    "params": {
      "threads": {
        "widget": "number",
        "label": "Threads"
      }
    }
  }
}
